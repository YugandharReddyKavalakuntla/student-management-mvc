@model StudentApp.Models.Student

<h2>Delete Student</h2>

<h4>Are you sure you want to delete this student?</h4>

<div class="mt-3">
    <strong>Name:</strong> @Model.Name
</div>

<div>
    <strong>Course:</strong> @Model.Course
</div>

<form asp-action="Delete" method="post" class="mt-3">

    <input type="hidden" asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>