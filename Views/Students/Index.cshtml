@model IEnumerable<StudentApp.Models.Student>

<h2>Students List</h2>

<a asp-action="Create" class="btn btn-primary">
    Add Student
</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Course</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.Course</td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@student.Id"
                       class="btn btn-warning">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@student.Id"
                       class="btn btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>