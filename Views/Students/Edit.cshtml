@model StudentApp.Models.Student

<h2>Edit Student</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Name</label>

        <input asp-for="Name"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Course</label>

        <input asp-for="Course"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-primary">
        Update
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back
    </a>

</form>